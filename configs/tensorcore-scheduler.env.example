# Example environment for the dedicated Tensorcore scheduler VM.
#
# Copy to /etc/tensorcore/scheduler.env on the scheduler host and adjust paths.
TC_MESH_ARBITER_CMD=/opt/computer_mesh/tsotchke/bin/tsotchke-arbiter
# For a remote arbiter endpoint, point TC_MESH_ARBITER_CMD at
# /opt/tensorcore/scripts/remote_tsotchke_arbiter.py and set:
# TC_REMOTE_ARBITER_HOST=arbiter.example
# TC_REMOTE_ARBITER_BIN=/opt/computer_mesh/tsotchke/bin/tsotchke-arbiter
# TC_REMOTE_ARBITER_KEY=/etc/tensorcore/arbiter_ssh_key
TC_SCHEDULER_ROOT=/var/lib/tensorcore
TC_SCHEDULER_JOBS_JSON=/var/lib/tensorcore/mesh_resource_jobs.json
TC_SCHEDULER_EVENT_LOG_JSONL=/var/lib/tensorcore/mesh_resource_queue_events.jsonl
TC_SCHEDULER_INVENTORY_JSON=/opt/tensorcore/configs/mesh_resources.json
TC_SCHEDULER_STATE_JSON=/var/lib/tensorcore/mesh_resource_state.json
TC_SCHEDULER_INTERVAL_SEC=30
TC_SCHEDULER_MAX_RUNNING_PER_TENANT=1
TC_GPU_RECONCILIATION_REPORTS_DIR=/var/lib/tensorcore/gpu-reconciliation
TC_GPU_RECONCILIATION_SWEEP_JSON=/var/lib/tensorcore/gpu-reconciliation-sweep.json
TC_GPU_RECONCILIATION_AUDIT_JSON=/var/lib/tensorcore/gpu-reconciliation-audit.json
TC_GPU_RECONCILIATION_MAX_AGE_SEC=120
